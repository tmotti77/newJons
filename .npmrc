enable-pre-post-scripts=true

# Expo SDK 54 / React Native / Metro expect a flat node_modules (npm/yarn style).
# Under pnpm's default isolated linker, @expo/cli can't resolve metro-runtime and
# native autolinking misbehaves. Hoisted linker is Expo's recommended setup for
# pnpm monorepos. See https://docs.expo.dev/guides/monorepos/
node-linker=hoisted
